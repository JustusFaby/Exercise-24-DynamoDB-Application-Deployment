{
	"info": {
		"_postman_id": "06d7e2e7-9d7a-4a25-a7b3-8a306fbc625b",
		"name": "Customer App API",
		"description": "API collection for testing the Customer DynamoDB Application.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/health",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"health"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create Customer",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"let responseData = pm.response.json();",
							"pm.environment.set(\"customerId\", responseData.customerId);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\":\"John\",\n    \"email\":\"john@gmail.com\",\n    \"phone\":\"9999999999\",\n    \"address\":\"Chennai\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/customers",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"customers"
					]
				}
			},
			"response": []
		},
		{
			"name": "Read Customer",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/customers/{{customerId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"customers",
						"{{customerId}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Update Customer",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"phone\": \"8888888888\",\n    \"address\": \"Bangalore\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/customers/{{customerId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"customers",
						"{{customerId}}"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000"
		}
	]
}
